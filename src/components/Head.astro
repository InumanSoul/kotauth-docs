---
/**
 * Custom Head override for Kotauth Docs.
 *
 * Injects a dark-theme forcing script BEFORE Starlight renders its own
 * inline theme-detection script. Starlight reads `localStorage.starlight-theme`
 * to decide which value to set on `document.documentElement.dataset.theme`.
 * By setting both the key and the attribute here we guarantee:
 *   1. The attribute is correct on the very first paint (no FOUT).
 *   2. Starlight's own script confirms 'dark' from localStorage and never
 *      overrides us to 'light' based on OS preference.
 *
 * Without this, users with a light-mode OS preference would get
 * data-theme='light' applied, which breaks Starlight's component-level
 * dark-theme CSS selectors and causes the card icon contrast issue.
 */
import Default from "@astrojs/starlight/components/Head.astro";
---

<script is:inline>
  (function () {
    localStorage.setItem("starlight-theme", "dark");
    document.documentElement.setAttribute("data-theme", "dark");
  })();
</script>

<Default {...Astro.props}><slot /></Default>
